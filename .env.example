OPENAI_API_KEY=sk-your-key-here

# Database Backend: "postgres" (default) oder "seatable"
DB_BACKEND=postgres

# PostgreSQL (Railway setzt DATABASE_URL automatisch)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# SeaTable (nur wenn DB_BACKEND=seatable)
SEATABLE_API_TOKEN=your-token-here
SEATABLE_BASE_UUID=your-uuid-here

# Dry-Run: true = keine echten E-Mails, alles landet in "email_test_log"
EMAIL_DRY_RUN=true

# Dashboard Auth
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme
JWT_SECRET=generate-a-random-secret-here
JWT_EXPIRY_HOURS=24
